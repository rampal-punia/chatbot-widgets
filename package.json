{
  "name": "chatbot-widgets",
  "version": "1.0.0",
  "private": true,
  "description": "Aparsoft AI Chatbot Widget -- framework wrappers for React, Next.js, Vue, and Angular",
  "repository": {
    "type": "git",
    "url": "https://github.com/aparsoft/chatbot-widgets.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "echo \"No build step required -- packages are thin wrappers.\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"packages/**/*.{js,jsx,ts,tsx,vue}\""
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
